module speech_vocoder (
    input  wire        clk,          // 4 MHz
    input  wire        reset,        // active high
    input  wire [17:0] pcm_in,       // 18-bit signed PCM from mic
    input  wire        pcm_valid,    // pulses at 62.5 kHz
    input  wire [2:0]  pitch_sel,    // switch[9:7]
    output reg  [17:0] pcm_out       // 18-bit signed vocoded output
);

    // -----------------------------------------------------------
    // 1. SAWTOOTH GENERATOR
    //    At 62.5 kHz sample rate:
    //    100 Hz -> period = 625 samples
    //    150 Hz -> period = 417 samples
    //    200 Hz -> period = 313 samples
    //    300 Hz -> period = 208 samples
    // -----------------------------------------------------------
    reg [9:0] saw_counter;
    reg [9:0] saw_period;
    reg [17:0] sawtooth; // unsigned 0..period-1, scaled to 18-bit

    always @(*) begin
        case (pitch_sel)
            3'd0: saw_period = 10'd624;
            3'd1: saw_period = 10'd624; // 100 Hz
            3'd2: saw_period = 10'd416; // 150 Hz
            3'd3: saw_period = 10'd312; // 200 Hz
            3'd4: saw_period = 10'd207; // 300 Hz
            default: saw_period = 10'd312;
        endcase
    end

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            saw_counter <= 0;
            sawtooth    <= 0;
        end else if (pcm_valid) begin
            if (saw_counter >= saw_period) begin
                saw_counter <= 0;
                sawtooth    <= 0;
            end else begin
                saw_counter <= saw_counter + 1;
                // scale counter to full 18-bit range:
                // sawtooth = (counter / period) * 2^18
                // approximate with shift: sawtooth ~ counter << 8
                // (works well enough for perceptual effect)
                sawtooth <= {saw_counter, 8'b0}; // counter in upper bits
            end
        end
    end

    // -----------------------------------------------------------
    // 2. ENVELOPE FOLLOWER
    //    Fast attack: alpha_attack  = 1/8   (shift 3)
    //    Slow release: alpha_release = 1/256 (shift 8)
    //    envelope tracks abs(pcm_in)
    // -----------------------------------------------------------
    reg [17:0] envelope; // unsigned magnitude tracker
    wire [17:0] abs_pcm = pcm_in[17] ? (~pcm_in + 1'b1) : pcm_in;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            envelope <= 0;
        end else if (pcm_valid) begin
            if (abs_pcm > envelope)
                // fast attack: envelope += (abs_pcm - envelope) >> 3
                envelope <= envelope + ((abs_pcm - envelope) >> 3);
            else
                // slow release: envelope -= (envelope - abs_pcm) >> 8
                envelope <= envelope - ((envelope - abs_pcm) >> 8);
        end
    end

    // -----------------------------------------------------------
    // 3. MULTIPLY envelope * sawtooth -> output
    //    Both are 18-bit unsigned, product is 36-bit.
    //    Take upper 18 bits, then convert to signed centered at 0.
    // -----------------------------------------------------------
    wire [35:0] product = envelope * sawtooth;
    // product[35:18] gives us the scaled result (0 to 2^18-1)
    // subtract half range to center around 0 (make signed)
    wire [17:0] product_scaled = product[35:18];
    wire [17:0] centered = product_scaled - 18'h1FFFF; // subtract ~half

    always @(posedge clk or posedge reset) begin
        if (reset)
            pcm_out <= 0;
        else if (pcm_valid)
            pcm_out <= centered;
    end

endmodule